---
interface ContentBlock {
  type: string;
  content: string;
  metadata?: Record<string, any>;
}

interface SectionContent {
  id: number;
  slug: string;
  blocks?: Record<string, ContentBlock>;
}

const content = Astro.props.content as SectionContent | undefined;
const blocks = content?.blocks ?? {};

const getBlockContent = (blockKey: string): string | undefined => {
  return blocks?.[blockKey]?.content;
};

// Extract content from API
const sectionLabel = getBlockContent('section_label') || 'Cómo Llegar';
const titulo = getBlockContent('titulo') || 'Encuéntranos';
const tituloHighlightWord = getBlockContent('titulo_highlight_word') || 'Fácilmente';
const subtitulo = getBlockContent('subtitulo') || 'Estamos en una zona céntrica y accesible para tu comodidad.';
const mapUrl = getBlockContent('map_url') || 'https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3930.1069284256373!2d-76.24007962408443!3d-9.925052106035078!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x91a7c326047a94db%3A0x9861c485037915b!2sConsultorio%20Ginecol%C3%B3gico%20JYZA!5e0!3m2!1ses!2spe!4v1774586756495!5m2!1ses!2spe';

// Helper to split title and highlight word
const getTitleParts = (title: string, highlightWord: string) => {
  if (!highlightWord || !title.includes(highlightWord)) {
    return { before: title, after: '' };
  }
  const parts = title.split(highlightWord);
  return { before: parts[0], after: parts[1] || '' };
};

const { before, after } = getTitleParts(titulo, tituloHighlightWord);
---

<section class="como-llegar-section">
  <div class="container">

    <div class="section-header">
      <div class="section-label">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/>
          <circle cx="12" cy="10" r="3"/>
        </svg>
        <span>{sectionLabel}</span>
      </div>
      <h2 class="section-title">
        {before} <span class="highlight">{tituloHighlightWord}</span>{after}
      </h2>
      <p class="section-subtitle">
        {subtitulo}
      </p>
    </div>
    <!-- Mapa grande -->
    <div class="map-wrapper">
      <iframe
        src={mapUrl}
        width="100%"
        height="100%"
        style="border:0;"
        allowfullscreen=""
        loading="lazy"
        referrerpolicy="no-referrer-when-downgrade"
        title="Ubicación en Google Maps"
      ></iframe>
    </div>

  </div>
</section>

<style>
  .como-llegar-section {
    padding: 5rem 0;
    background: var(--color-segunda-bg);
  }

  .container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 2rem;
  }

  /* Header — idéntico al de servicios */
  .section-header {
    text-align: center;
    margin-bottom: 4rem;
  }

  .section-label {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.5rem 1rem;
    background: var(--color-fondo-badge);
    color: var(--color-texto-badge);
    font-size: 0.875rem;
    font-weight: 500;
    border-radius: 20px;
    border: 1.5px solid var(--color-border-badge);
    width: fit-content;
    text-transform: uppercase;
  }

  .label-icon { width: 16px; height: 16px; }

  .section-title {
    font-size: 2.5rem;
    font-weight: 700;
    line-height: 1.2;
    color: var(--color-especialidades-title) !important;
    margin: 0.5rem 0 1rem 0;
  }

  .highlight { color: var(--color-violeta); }

  .section-subtitle {
    font-size: 1rem;
    color: var(--color-text);
    opacity: 0.7;
    margin: 0 auto;
    max-width: 600px;
  }

  /* Mapa */
  .map-wrapper {
    position: relative;
    height: 500px;
    border-radius: 24px;
    overflow: hidden;
    box-shadow: 0 0 6px rgba(0,0,0,0.19);
    border: 1px solid #E6E1E5;
  }

  .map-wrapper iframe {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    border-radius: 10px;
  }
  /* Responsive — idéntico a services-section */
  @media (max-width: 968px) {
    .section-title { font-size: 2rem; }
  }

  @media (max-width: 640px) {
    
    .como-llegar-section { padding: 3rem 0; }
    .section-header { margin-bottom: 2rem; }
    .section-title { font-size: 1.6rem; }
    .section-subtitle { font-size: 1rem; }
    .map-wrapper { height: 340px; }
  }
</style>