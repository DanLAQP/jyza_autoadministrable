---
interface ContentBlock {
  type: string;
  content: string;
  metadata?: Record<string, any>;
}

interface SectionContent {
  id: number;
  slug: string;
  title?: string;
  description?: string;
  metadata?: Record<string, any>;
  blocks?: Record<string, ContentBlock>;
  images?: Array<{
    id: number;
    url: string;
    alt: string;
    title?: string;
    dimensions?: string;
  }>;
}

const content = Astro.props.content as SectionContent | undefined;
const blocks = content?.blocks ?? {};
const images = content?.images ?? [];

const getBlockContent = (blockKey: string, fallback: string): string => {
  return blocks?.[blockKey]?.content || fallback;
};

const getStatLabel = (blockKey: string, defaultLabel: string): string => {
  const block = blocks?.[blockKey];
  if (!block) return defaultLabel;

  let metadata = block.metadata;
  if (typeof metadata === 'string') {
    try {
      metadata = JSON.parse(metadata);
    } catch {
      metadata = block.metadata;
    }
  }

  return metadata?.label || defaultLabel;
};

const getImageUrl = (imageId: string | number): string => {
  if (!imageId) return '';
  const image = images.find(img => String(img.id) === String(imageId));
  return image?.url || '';
};

const sectionLabel = blocks?.['section_label']?.content;
const titleNormal = blocks?.['titulo_normal']?.content || 'Tu Bienestar es';
const titleHighlight = blocks?.['titulo_highlight']?.content || 'Nuestra Prioridad';
const description = blocks?.['descripcion']?.content;

const stat1Number = blocks?.['stat_1_number']?.content;
const stat1Label = blocks?.['stat_1_number'] ? getStatLabel('stat_1_number', '') : undefined;

const stat2Number = blocks?.['stat_2_number']?.content;
const stat2Label = blocks?.['stat_2_number'] ? getStatLabel('stat_2_number', '') : undefined;

const stat3Number = blocks?.['stat_3_number']?.content;
const stat3Label = blocks?.['stat_3_number'] ? getStatLabel('stat_3_number', '') : undefined;

const stat4Number = blocks?.['stat_4_number']?.content;
const stat4Label = blocks?.['stat_4_number'] ? getStatLabel('stat_4_number', '') : undefined;

const feature1 = blocks?.['feature_1_text']?.content;
const feature2 = blocks?.['feature_2_text']?.content;
const feature3 = blocks?.['feature_3_text']?.content;

const img1Url = getImageUrl(blocks['img_1']?.content);
const img2Url = getImageUrl(blocks['img_2']?.content);
const img3Url = getImageUrl(blocks['img_3']?.content);
const img4Url = getImageUrl(blocks['img_4']?.content);
---

<section class="about-section">
  <div class="container">
    <div class="about-content">
      <!-- Galería de imágenes -->
      <div class="about-gallery">
        <div class="gallery-grid">
          <img src={img1Url || '/imag1.webp'} alt="Doctor con equipo médico" class="gallery-img img-1" loading="lazy" width="350" height="280" />
          <img src={img2Url || '/imag2.webp'} alt="Equipo quirúrgico" class="gallery-img img-2" loading="lazy" width="350" height="280" />
          <img src={img3Url || '/imag3.webp'} alt="Sala de operaciones" class="gallery-img img-3" loading="lazy" width="350" height="280" />
          <img src={img4Url || '/imag4.webp'} alt="Doctor en cirugía" class="gallery-img img-4" loading="lazy" width="350" height="280" />
        </div>
      </div>

      <!-- Contenido de texto -->
      <div class="about-text">
        {sectionLabel && (
          <div class="section-label">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="label-icon">
              <polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"></polygon>
            </svg>
            <span>{sectionLabel}</span>
          </div>
        )}

        {(titleNormal || titleHighlight) && (
          <h2 class="section-title">
            {titleNormal && <span>{titleNormal}</span>}
            {titleHighlight && <span class="highlight">{titleHighlight}</span>}
          </h2>
        )}

        {description && (
          <p class="section-description">
            {description}
          </p>
        )}

        <!-- Stats Grid -->
        {(stat1Number || stat2Number || stat3Number || stat4Number) && (
          <div class="stats-grid">
            {stat1Number && (
              <div class="stat-card">
                <div class="stat-number">{stat1Number}</div>
                <div class="stat-label">{stat1Label}</div>
              </div>
            )}
            {stat2Number && (
              <div class="stat-card">
                <div class="stat-number">{stat2Number}</div>
                <div class="stat-label">{stat2Label}</div>
              </div>
            )}
            {stat3Number && (
              <div class="stat-card">
                <div class="stat-number">{stat3Number}</div>
                <div class="stat-label">{stat3Label}</div>
              </div>
            )}
            {stat4Number && (
              <div class="stat-card">
                <div class="stat-number">{stat4Number}</div>
                <div class="stat-label">{stat4Label}</div>
              </div>
            )}
          </div>
        )}

        <!-- Features List -->
        {(feature1 || feature2 || feature3) && (
          <div class="features-list">
            {feature1 && (
              <div class="feature-item">
                <div class="check-icon">
                  <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round">
                    <polyline points="20 6 9 17 4 12"></polyline>
                  </svg>
                </div>
                <span>{feature1}</span>
              </div>
            )}
            {feature2 && (
              <div class="feature-item">
                <div class="check-icon">
                  <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round">
                    <polyline points="20 6 9 17 4 12"></polyline>
                  </svg>
                </div>
                <span>{feature2}</span>
              </div>
            )}
            {feature3 && (
              <div class="feature-item">
                <div class="check-icon">
                  <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round">
                    <polyline points="20 6 9 17 4 12"></polyline>
                  </svg>
                </div>
                <span>{feature3}</span>
              </div>
            )}
          </div>
        )}
      </div>
    </div>
  </div>
</section>

<style>
  .about-section {
    padding: 5rem 0;
    background: var(--color-segunda-bg);
    display: flex;
    align-items: center;
  }

  .container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 2rem;
    width: 100%;
  }

  .about-content {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 4rem;
    align-items: center;
  }

  .about-gallery {
    position: relative;
    margin-top: 100px;
  }

  .gallery-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    grid-template-rows: auto auto;
    gap: 1rem;
    height: 550px;
  }

  .gallery-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    border-radius: 20px;
  }

  .img-1 {
    grid-row: 1 / 2;
    grid-column: 1 / 2;
    height: 280px;
  }

  .img-2 {
    grid-row: 1 / 2;
    grid-column: 2 / 3;
    height: 180px;
    margin-top: 2rem;
  }

  .img-3 {
    grid-row: 2 / 3;
    grid-column: 1 / 2;
    height: 180px;
    margin-top: -2.5rem;
  }

  .img-4 {
    grid-row: 2 / 3;
    grid-column: 2 / 3;
    height: 280px;
    margin-top: -6.8rem;
  }

  .about-text {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .section-label {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.5rem 1rem;
    background: var(--color-fondo-badge);
    color: var(--color-texto-badge);
    font-size: 0.875rem;
    font-weight: 500;
    border-radius: 20px;
    border: 1.5px solid var(--color-border-badge);
    width: fit-content;
  }

  .label-icon {
    width: 16px;
    height: 16px;
    color: var(--color-texto-badge);
  }

  .section-title {
    font-size: 2rem;
    font-weight: 700;
    line-height: 1.2;
    color: var(--color-dark) !important;
    margin: 0;
  }

  .section-title span {
    display: inline;
  }

  .highlight {
    color: var(--color-violeta);
    font-weight: 700;
  }

  .section-description {
    color: var(--color-text);
    font-size: 1rem;
    line-height: 1.6;
    margin: 0;
    opacity: 0.8;
  }

  .stats-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1rem;
    margin: 1rem 0;
  }

  .stat-card {
    background: white;
    padding: 1.2rem;
    border-radius: 12px;
    box-shadow: 0 0 6px rgba(0, 0, 0, 0.19);
  }

  .stat-number {
    font-size: 2rem;
    font-weight: 700;
    color: var(--color-dark);
    margin-bottom: 0.25rem;
  }

  .stat-label {
    font-size: 0.875rem;
    color: var(--color-dark);
    opacity: 0.7;
  }

  .features-list {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .feature-item {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    color: var(--color-text);
    font-size: 0.95rem;
  }

  .check-icon {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 28px;
    height: 28px;
    background: var(--color-violeta);
    color: white;
    border-radius: 9px;
    flex-shrink: 0;
  }

  /* Responsive */
  @media (max-width: 768px) {
    .about-section {
      padding: 0;
      min-height: 100vh;
      min-height: 100dvh;
      display: flex;
      align-items: center;
    }

    .container {
      padding: 2rem 1.5rem;
    }

    .about-content {
      grid-template-columns: 1fr;
      gap: 1.25rem;
    }

    /* Ocultar galería en mobile */
    .about-gallery {
      display: none;
    }

    .about-text {
      gap: 1rem;
    }

    .section-title {
      font-size: 1.5rem;
      white-space: normal;
    }

    .section-description {
      font-size: 0.9rem;
    }

    /* Stats centrado y más estrecho */
    .stats-grid {
      grid-template-columns: repeat(2, 1fr);
      gap: 0.75rem;
      width: 85%;
      margin: 0.5rem auto;
    }

    .stat-card {
      padding: 0.875rem 1rem;
    }

    .stat-number {
      font-size: 1.4rem;
    }

    .stat-label {
      font-size: 0.775rem;
    }

    .features-list {
      gap: 0.75rem;
    }

    .feature-item {
      font-size: 0.875rem;
    }
  }
</style>