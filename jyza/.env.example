# .env.example - Copiar a .env.local
# ===========================================
# Configuración de la API Backend

# URL base del API CakePHP
# En desarrollo:
PUBLIC_API_URL=http://localhost:3000

# En producción:
# PUBLIC_API_URL=https://api.jyza.com

# Caché de contenido en el cliente (en segundos)
PUBLIC_CACHE_TTL=3600

# Modo debug (true/false)
PUBLIC_DEBUG=false

# Variables privadas (accesibles solo en el servidor)
# (Si tienes tokens o keys secretas para Astro)

# CORS allowed origins (para futuras APIs)
ALLOWED_ORIGINS=http://localhost:3000,https://jyza.com,https://www.jyza.com

# CDN URL para imágenes (opcional)
CDN_URL=https://cdn.jyza.com
