---
// src/components/landing/Bienvenida.astro
interface ContentBlock {
  type: string;
  content: string;
  metadata?: Record<string, any>;
}

interface SectionContent {
  id: number;
  slug: string;
  title?: string;
  description?: string;
  metadata?: Record<string, any>;
  blocks?: Record<string, ContentBlock>;
  images?: Array<{
    id: number;
    url: string;
    alt: string;
    title?: string;
    dimensions?: string;
  }>;
}

const content = Astro.props.content as SectionContent | undefined;
const blocks = content?.blocks ?? {};
const images = content?.images ?? [];
const imageById = new Map(images.map((image) => [String(image.id), image]));

const getBlockContent = (blockKey: string, fallback: string): string => {
  return blocks?.[blockKey]?.content || fallback;
};

const getImageByBlock = (blockKeys: string[], fallback?: (typeof images)[number]) => {
  for (const blockKey of blockKeys) {
    const raw = blocks?.[blockKey]?.content?.trim?.();
    if (!raw) {
      continue;
    }

    // Si el contenido parece una URL o ruta, devolverla directamente
    if (raw.startsWith('/') || raw.startsWith('http')) {
      return {
        id: 0,
        url: raw,
        alt: blocks?.[blockKey]?.metadata?.alt || '',
        title: blocks?.[blockKey]?.metadata?.title || undefined,
      };
    }

    // Si es un id, buscar en images
    const image = imageById.get(raw);
    if (image) {
      return image;
    }
  }

  return fallback;
};

const tituloParte1 = blocks?.['titulo_parte1']?.content;
const tituloParte2 = blocks?.['titulo_parte2']?.content;
const tituloParte3 = blocks?.['titulo_parte3']?.content;
const description = blocks?.['descripcion']?.content;
const badgeText = blocks?.['badge_text']?.content;
const ctaButtonText = getBlockContent('cta_button_text', 'Agendar Cita por WhatsApp');
const ctaButtonUrl = getBlockContent('cta_button_url', 'https://wa.me/51961295024?text=Hola,%20deseo%20agendar%20una%20cita');
const ctaSecondaryText = blocks?.['cta_secundario_text']?.content;
const ubicacion = blocks?.['ubicacion']?.content;
const ubicacionDetail = blocks?.['ubicacion_detail']?.content;
const horarios = blocks?.['horarios']?.content;
const horariosDetail = blocks?.['horarios_detail']?.content;
const clubButtonLabel = blocks?.['club_button_label']?.content ?? 'Únete';
const clubButtonTitle = blocks?.['club_button_title']?.content ?? 'Club JYZA';
const clubButtonUrl = blocks?.['club_button_url']?.content ?? 'https://wa.me/51961295024?text=Hola,%20deseo%20inscribirme%20al%20Club%20JYZA';
const clubButtonAria = blocks?.['club_button_aria']?.content ?? 'Inscríbete al Club JYZA por WhatsApp';

const heroImage = getImageByBlock(['hero_background_image', 'background_image', 'hero_image'], images[0]);
const heroMobileImage = getImageByBlock(['hero_background_mobile_image', 'background_mobile_image'], heroImage);
const logoImage = getImageByBlock(['logo_image', 'hero_logo_image'], undefined);
const logoMobileImage = getImageByBlock(['logo_mobile_image', 'hero_logo_mobile_image'], logoImage);
const buttonIconImage = getImageByBlock(['button_icon_image', 'cta_icon_image'], undefined);
---
<section class="hero">
  <div class="hero-background">
    <div class="hero-gradient"></div>
    <picture>
      <source media="(max-width: 1024px)" srcset={heroMobileImage?.url || './herofondot.webp'} />
      <img src={heroImage?.url || './herofondo.webp'} alt={heroImage?.alt || 'Clínica Ginecología Huánuco'} loading="eager" width="1920" height="1080" />
    </picture>
  </div>
  <a
    href={clubButtonUrl}
    class="club-jyza-btn"
    target="_blank"
    aria-label={clubButtonAria}
  >
    <svg class="club-jyza-icon" width="18" height="18" viewBox="0 0 24 24" aria-hidden="true">
      <path d="M12 2.5l2.9 5.88 6.49.94-4.69 4.57 1.11 6.46L12 17.95 6.19 20.35l1.11-6.46-4.69-4.57 6.49-.94L12 2.5z" fill="currentColor"/>
    </svg>
    <div class="club-jyza-text">
      <span class="club-jyza-label">{clubButtonLabel}</span>
      <span class="club-jyza-title">{clubButtonTitle}</span>
    </div>
    <svg class="club-jyza-arrow" width="16" height="16" viewBox="0 0 20 20" fill="none">
      <path d="M7.5 15L12.5 10L7.5 5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
    </svg>
  </a>
  <div class="hero-container">
    <img src={logoImage?.url || './logoJiza.webp'} alt={logoImage?.alt || 'Logo Jiza'} class="logo-hero" width="200" height="200" />

    <div class="hero-content">
      <img src={logoMobileImage?.url || './logoJiza.webp'} alt={logoMobileImage?.alt || 'Logo Jiza'} class="logo-hero-mobile" width="120" height="120" />

      {badgeText && (
        <div class="hero-badge">
          <span class="badge-icon"></span>
          <span class="badge-text">{badgeText}</span>
        </div>
      )}

      {(tituloParte1 || tituloParte2 || tituloParte3) && (
        <h1 class="hero-title">
          {tituloParte1 && <>{tituloParte1}<br /></>}
          {tituloParte2 && <><span class="highlight">{tituloParte2}</span><br /></>}
          {tituloParte3 && <>{tituloParte3}</>}
        </h1>
      )}

      {description && <p class="hero-description" set:html={description} />}

      {(ctaButtonText || ctaSecondaryText) && (
        <div class="hero-actions">
          {ctaButtonText && (
            <a href={ctaButtonUrl} class="btn-primary" target="_blank">
              <img src={buttonIconImage?.url || 'iconBtn.webp'} alt={buttonIconImage?.alt || 'icono'} width="20" height="20">
              {ctaButtonText}
            </a>
          )}

          {ctaSecondaryText && (
            <a href="#servicios" class="btn-secondary">
              <span class="btn-separator">ó</span>
              {ctaSecondaryText}
              <svg width="20" height="20" viewBox="0 0 20 20" fill="none" xmlns="http://www.w3.org/2000/svg" class="arrow-down">
                <path d="M7.5 15L12.5 10L7.5 5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
              </svg>
            </a>
          )}
        </div>
      )}

      <div class="hero-info">
        {ubicacion && (
          <div class="info-card">
            <div class="info-icon">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                <path d="M12 2C7.58 2 4 5.58 4 10c0 7 8 13 8 13s8-6 8-13c0-4.42-3.58-8-8-8zm0 11c-1.66 0-3-1.34-3-3s1.34-3 3-3 3 1.34 3 3-1.34 3-3 3z"/>
              </svg>
            </div>
            <div class="info-text">
              <span class="info-label">{ubicacion}</span>
              <span class="info-detail">{ubicacionDetail}</span>
            </div>
          </div>
        )}

        {horarios && (
          <div class="info-card">
            <div class="info-icon">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                <rect x="3" y="4" width="18" height="18" rx="2"/>
                <path d="M16 2v4M8 2v4M3 10h18"/>
              </svg>
            </div>
            <div class="info-text">
              <span class="info-label">{horarios}</span>
              <span class="info-detail">{horariosDetail}</span>
            </div>
          </div>
        )}
      </div>
    </div>
  </div>
</section>

