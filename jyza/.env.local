# .env.local - Configuración local para desarrollo

# URL base del API Backend (Docker)
# En Docker, jyza-admin es el nombre del container
PUBLIC_API_URL=http://jyza-admin:8000

# Para desarrollo local (sin Docker), usa:
# PUBLIC_API_URL=http://localhost:8000

# Caché de contenido en el cliente (en segundos)
PUBLIC_CACHE_TTL=3600

# Modo debug
PUBLIC_DEBUG=true

# Variables para futuras APIs
ALLOWED_ORIGINS=http://localhost:4321,http://localhost:8000,http://jyza-admin:8000

# CDN URL para imágenes (opcional)
CDN_URL=http://localhost:8000
