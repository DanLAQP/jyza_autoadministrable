# Cache Headers para optimización de carga ⚡

# Imágenes - Caché largo (365 días = 31536000 segundos)
/paquete*.jpg
  Cache-Control: public, max-age=31536000, immutable

/especialidad*.png
  Cache-Control: public, max-age=31536000, immutable

/equipo*.png
  Cache-Control: public, max-age=31536000, immutable

/imag*.png
  Cache-Control: public, max-age=31536000, immutable

/avatar*.jpg
  Cache-Control: public, max-age=31536000, immutable

/herofondot.png
  Cache-Control: public, max-age=31536000, immutable

/*.png
  Cache-Control: public, max-age=31536000, immutable

/*.jpg
  Cache-Control: public, max-age=31536000, immutable

# Assets compilados de Astro - Caché muy largo (inmutal)
/_astro/*
  Cache-Control: public, max-age=31536000, immutable

# CSS y JS compilados - Caché largo
/*.css
  Cache-Control: public, max-age=31536000, immutable

/*.js
  Cache-Control: public, max-age=31536000, immutable

# HTML - Caché corto (1 hora) para detectar cambios rápidamente
/*.html
  Cache-Control: public, max-age=3600, must-revalidate

# Documento raíz - Caché muy corto (5 minutos)
/index.html
  Cache-Control: public, max-age=300, must-revalidate

# Sin extensión (probablemente será index.html)
/
  Cache-Control: public, max-age=300, must-revalidate
