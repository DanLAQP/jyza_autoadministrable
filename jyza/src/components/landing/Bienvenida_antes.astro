---
// src/components/landing/Bienvenida.astro
---
<section class="hero">
  <div class="hero-background">
    <div class="hero-gradient"></div>
    <picture>
      <source media="(max-width: 1024px)" srcset="./herofondot.webp" />
      <img src="./herofondo.webp" alt="Clínica Ginecología Huánuco" loading="eager" width="1920" height="1080" />
    </picture>
  </div>
  
  <div class="hero-container">
    <img src="./logoJiza.webp" alt="Logo Jyza" class="logo-hero" width="200" height="200" />
    
    <div class="hero-content">
      <img src="./logoJiza.webp" alt="Logo Jyza" class="logo-hero-mobile" width="120" height="120" />
      
      <div class="hero-badge">
        <span class="badge-icon"></span>
        <span class="badge-text">CITAS DISPONIBLES ESTA SEMANA</span>
      </div>
      
      <h1 class="hero-title">
        Tu Salud Femenina
        en las <span class="highlight">Mejores
        Manos</span> de Huánuco
      </h1>
      
      <p class="hero-description">
        Clínica especializada en ginecología y obstetricia con más de 10<br />
        años cuidando la salud integral de la mujer. Tecnología avanzada<br />
        y atención personalizada.
      </p>
      
      <div class="hero-actions">
        <a href="https://wa.me/51961295024?text=Hola,%20deseo%20agendar%20una%20cita" class="btn-primary" target="_blank">
          <img src="iconBtn.webp" alt="icono" width="20" height="20">
          Agendar Cita por WhatsApp
        </a>


        
        <a href="#servicios" class="btn-secondary">
          <span class="btn-separator">ó</span>
          Ver servicios
          <svg width="20" height="20" viewBox="0 0 20 20" fill="none" xmlns="http://www.w3.org/2000/svg" class="arrow-down">
            <path d="M7.5 15L12.5 10L7.5 5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
          </svg>
        </a>
      </div>
      
      <div class="hero-info">
        <div class="info-card">
          <div class="info-icon">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
              <path d="M12 2C7.58 2 4 5.58 4 10c0 7 8 13 8 13s8-6 8-13c0-4.42-3.58-8-8-8zm0 11c-1.66 0-3-1.34-3-3s1.34-3 3-3 3 1.34 3 3-1.34 3-3 3z"/>
            </svg>
          </div>
          <div class="info-text">
            <span class="info-label">Jirón Dos de Mayo 1600 con Pedro Puelles</span>
            <span class="info-detail">Esquina del Parque Amarilis, Huánuco</span>
          </div>
        </div>
        
        <div class="info-card">
          <div class="info-icon">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
              <rect x="3" y="4" width="18" height="18" rx="2"/>
              <path d="M16 2v4M8 2v4M3 10h18"/>
            </svg>
          </div>
          <div class="info-text">
            <span class="info-label">Lunes a Domingo</span>
            <span class="info-detail">8:00 am - 9:00 pm</span>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .hero {
    width: 100%;
    min-height: 100vh;
    min-height: 100dvh;
    position: relative;
    overflow: hidden;
    display: flex;
    align-items: center;
  }
  
  .hero-background {
    position: absolute;
    inset: 0;
    z-index: 0;
  }
  
  .hero-background img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
  }
  
  .hero-gradient {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      90deg,
      rgba(21, 0, 18, 1) 0%,
      rgba(21, 0, 18, 0.85) 40%,
      rgba(72, 41, 59, 0.6) 60%,
      rgba(21, 0, 18, 0.2) 100%
    );
  }
  
  @media (max-width: 768px) {
    .hero-gradient {
      background: linear-gradient(
        110deg,
        rgba(21, 0, 18, 1) 0%,
        rgba(21, 0, 18, 0.85) 35%,
        rgba(72, 41, 59, 0.6) 65%,
        rgba(21, 0, 18, 0.2) 100%
      );
    }
  }
  
  .hero-container {
    max-width: 1400px;
    margin: 0 auto;
    padding: 4rem 2rem;
    width: 100%;
    position: relative;
    z-index: 1;
  }
  
  /* ✅ MODIFICADO: reducido de 700px a 580px */
  .hero-content {
    max-width: 580px;
  }
  
  .logo-hero {
    max-width: 100px;
    height: auto;
    position: absolute;
    top: -2rem;
    left: 2rem;
    z-index: 10;
    display: block;
  }

  .logo-hero-mobile {
    display: none;
  }
  
  .hero-badge {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    background: var(--color-citas);
    border: 1px solid var(--color-border-citas);
    border-radius: 50px;
    padding: 0.5rem 1rem;
    margin-bottom: 2rem;
    backdrop-filter: blur(10px);
  }
  
  .badge-icon {
    display: inline-block;
    width: 8px;
    height: 8px;
    background-color: var(--color-border-citas);
    border-radius: 50%;
    vertical-align: middle;
  }

  
  .badge-text {
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 1px;
    color: var(--color-violeta-light);
  }
  
  /* ✅ MODIFICADO: reducido de 4.5rem a 3.5rem */
  .hero-title {
    font-family: 'Urbanist', sans-serif;
    font-size: 3.5rem;
    font-weight: 700;
    line-height: 1.1;
    margin: 0 0 1.5rem 0;
    color: #fff;
  }
  
  .highlight {
    color: var(--color-violeta);
    font-family: 'Urbanist', sans-serif;
  }
  
  .hero-description {
    font-family: 'Urbanist', sans-serif;
    font-size: 1.125rem;
    line-height: 1.7;
    color: #fff;
    margin: 0 0 2.5rem 0;
    opacity: 0.95;
  }
  
  .hero-actions {
    display: flex;
    gap: 1rem;
    margin-bottom: 3rem;
    flex-wrap: wrap;
  }
  
  .btn-primary {
    display: inline-flex;
    align-items: center;
    gap: 0.75rem;
    background: var(--color-btn-primary);
    color: white;
    padding: 1rem 2rem;
    border-radius: 25px;
    font-weight: 600;
    text-decoration: none;
    transition: all 0.3s ease;
    font-family: 'Urbanist', sans-serif;
  }
  
  .btn-primary:hover {
    background: var(--color-btn-primary-hover);
    transform: translateY(-2px);
  }
  
  .btn-secondary {
    display: inline-flex;
    align-items: center;
    gap: 1.5rem;
    background: transparent;
    color: white;
    padding: 1rem 2rem;
    border-radius: 12px;
    font-weight: 600;
    text-decoration: none;
    transition: all 0.3s ease;
    font-family: 'Urbanist', sans-serif;
    backdrop-filter: blur(5px);
  }
  
  .btn-secondary:hover {
    border-color: rgba(255, 255, 255, 0.85); /* Mejorado: 0.5 → 0.85 */
    background: rgba(255, 255, 255, 0.12); /* Mejorado: 0.08 → 0.12 */
    transform: translateY(-2px);
  }

  .btn-separator {
    margin-right: 0.5rem;
    opacity: 0.8;
  }

  .arrow-down {
    transform: rotate(90deg);
    transition: transform 0.3s ease;
  }
  
  .hero-info {
    display: flex;
    gap: 1.5rem;
    flex-wrap: wrap;
  }

  .info-card {
    display: flex;
    align-items: center;
    gap: 1rem;
    background: var(--color-plomo);
    border: 1px solid var(--color-border-plomo);
    padding: 1rem 2rem;
    border-radius: 20px;
    backdrop-filter: blur(10px);
    flex: 1;
    min-width: 250px;
  }

  .info-icon {
    display: flex;
    align-items: center;
    justify-content: center;
    background-color: var(--color-fondo-icon);
    color: #E9D5F0;
    font-size: 1.5rem;
    border-radius: 20px;
    padding: 0.75rem;
    min-width: 50px;
    height: 50px;
  }

  .info-text {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }

  .info-label {
    font-family: 'Urbanist', sans-serif;
    font-weight: 600;
    font-size: 0.95rem;
    color: #fff;
  }

  .info-detail {
    font-family: 'Urbanist', sans-serif;
    font-size: 0.85rem;
    color: rgba(255, 255, 255, 0.75);
  }

  .iconBtn {
    vertical-align: middle;
  }

  /* ✅ MODIFICADO: Laptops grandes — título reducido de 5rem a 4rem */
  @media (min-width: 1440px) {
    .hero-container {
      padding: 4rem 2.5rem;
    }

    .hero-content {
      max-width: 560px;
    }

    .hero-title {
      font-size: 3.5rem;
      margin-bottom: 1.5rem;
    }

    .hero-description {
      font-size: 1rem;
      margin-bottom: 2.25rem;
    }

    .btn-primary {
      padding: 0.8rem 1.5rem;
      font-size: 0.9rem;
    }

    .btn-secondary {
      padding: 0.8rem 1.5rem;
      font-size: 0.9rem;
    }

    .hero-info {
      gap: 0.875rem;
    }

    .info-card {
      padding: 0.75rem 1.25rem;
      min-width: 200px;
    }

    .info-icon {
      min-width: 42px;
      height: 42px;
    }

    .info-label {
      font-size: 0.85rem;
    }

    .info-detail {
      font-size: 0.75rem;
    }
  }

  /* ✅ MODIFICADO: Laptops medianas — título reducido de 4.25rem a 3.75rem */
  @media (min-width: 1200px) and (max-width: 1439px) {
    .hero-container {
      padding: 4rem 2rem;
    }

    .hero-title {
      font-size: 3.25rem;
      margin-bottom: 1.5rem;
    }

    .hero-description {
      font-size: 0.95rem;
      margin-bottom: 2rem;
    }

    .btn-primary {
      padding: 0.75rem 1.4rem;
      font-size: 0.85rem;
    }

    .btn-secondary {
      padding: 0.75rem 1.4rem;
      font-size: 0.85rem;
    }

    .hero-info {
      gap: 0.875rem;
    }

    .info-card {
      padding: 0.75rem 1.25rem;
      min-width: 200px;
    }

    .info-icon {
      min-width: 42px;
      height: 42px;
    }

    .info-label {
      font-size: 0.85rem;
    }

    .info-detail {
      font-size: 0.75rem;
    }
  }

  /* Pantallas intermedias 1024px-1199px */
  @media (min-width: 1024px) and (max-width: 1199px) {
    .hero-container {
      padding: 2.5rem 1.5rem;
    }

    .hero-title {
      font-size: 2.5rem;
      margin-bottom: 1rem;
    }

    .hero-description {
      font-size: 0.85rem;
      margin-bottom: 1.5rem;
    }

    .hero-badge {
      margin-bottom: 0.6rem;
    }

    .hero-actions {
      gap: 0.6rem;
      margin-bottom: 1.25rem;
    }

    .btn-primary {
      padding: 0.7rem 1.3rem;
      font-size: 0.8rem;
    }

    .btn-secondary {
      padding: 0.7rem 1.3rem;
      font-size: 0.8rem;
      gap: 0.9rem;
    }

    .hero-info {
      gap: 0.75rem;
    }

    .info-card {
      padding: 0.65rem 1.1rem;
      min-width: 180px;
    }

    .info-icon {
      min-width: 38px;
      height: 38px;
    }

    .info-label {
      font-size: 0.8rem;
    }

    .info-detail {
      font-size: 0.7rem;
    }
  }

  /* Tablets medianas */
  @media (min-width: 800px) and (max-width: 1023px) {
    .hero-container {
      padding: 2rem 1.5rem;
    }

    .hero-title {
      font-size: 2.5rem;
      line-height: 1.2;
      margin-bottom: 1rem;
    }

    .hero-description {
      font-size: 0.95rem;
      line-height: 1.6;
      margin-bottom: 1.5rem;
    }

    .hero-badge {
      margin-bottom: 1rem;
      padding: 0.4rem 0.9rem;
    }

    .badge-text {
      font-size: 0.7rem;
    }

    .hero-actions {
      gap: 0.875rem;
      margin-bottom: 2rem;
    }

    .btn-primary {
      padding: 0.85rem 1.75rem;
      font-size: 0.9rem;
    }

    .btn-secondary {
      padding: 0.85rem 1.75rem;
      font-size: 0.9rem;
    }

    .hero-info {
      gap: 1rem;
    }

    .info-card {
      padding: 0.875rem 1.5rem;
      min-width: 220px;
    }

    .info-icon {
      min-width: 45px;
      height: 45px;
    }

    .info-label {
      font-size: 0.9rem;
    }

    .info-detail {
      font-size: 0.8rem;
    }
  }

  /* Tablets pequeñas */
  @media (min-width: 640px) and (max-width: 700px) {
    .hero-container {
      padding: 2rem 1.25rem;
    }

    .hero-title {
      font-size: 2.25rem;
      line-height: 1.2;
      margin-bottom: 1rem;
    }

    .hero-description {
      font-size: 0.95rem;
      line-height: 1.55;
      margin-bottom: 1.5rem;
      max-width: 90%;
    }

    .hero-actions {
      flex-direction: column;
      gap: 0.75rem;
      margin-bottom: 1.75rem;
    }

    .btn-primary {
      width: fit-content;
      padding: 0.8rem 1.5rem;
      font-size: 0.85rem;
    }

    .btn-secondary {
      width: auto;
      padding: 0;
      font-size: 0.85rem;
    }

    .hero-info {
      gap: 0.75rem;
      flex-direction: column;
    }

    .info-card {
      width: auto;
      padding: 0.6rem 1rem;
    }

    .info-icon {
      min-width: 40px;
      height: 40px;
    }

    .info-label {
      font-size: 0.85rem;
    }

    .info-detail {
      font-size: 0.75rem;
    }
  }
  
  /* Responsive */
  @media (max-width: 1024px) {
    .hero-container {
      padding: 3rem 1.5rem;
    }
    
    .hero-title {
      font-size: 3.5rem;
    }
  }
  
  @media (max-width: 768px) {
    .logo-hero {
      display: none;
    }

    .logo-hero-mobile {
      display: block;
      max-width: 65px;
      height: auto;
      margin-bottom: 2.5rem;
    }

    .hero {
      min-height: 100vh;
      min-height: 100dvh;
      padding: 0;
      align-items: center;
      box-sizing: border-box;
    }

    .hero-container {
      padding: 1.25rem 1.25rem;
      display: flex;
      align-items: center;
      justify-content: center;
      min-height: 100vh;
      min-height: 100dvh;
      box-sizing: border-box;
    }

    .hero-content {
      display: flex;
      flex-direction: column;
      align-items: flex-start;
      text-align: left;
      width: 100%;
    }

    .hero-title {
      font-size: 1.85rem;
      line-height: 1.15;
      margin-bottom: 0.75rem;
      max-width: 80%;
    }

    .hero-description {
      font-size: 0.875rem;
      line-height: 1.55;
      margin-bottom: 1.25rem;
      max-width: 80%;
    }

    .hero-badge {
      padding: 0.25rem 0.6rem;
      margin-bottom: 0.6rem;
    }

    .badge-icon {
      width: 6px;
      height: 6px;
    }

    .badge-text {
      font-size: 0.6rem;
      letter-spacing: 0.5px;
    }
    
    .hero-description br {
      display: none;
    }

    .hero-actions {
      flex-direction: column;
      align-items: center;
      align-self: stretch;
      gap: 0.6rem;
      margin-bottom: 1rem;
    }

    .btn-primary {
      width: fit-content;
      justify-content: center;
      padding: 0.65rem 1.5rem;
      font-size: 0.825rem;
    }

    .btn-secondary {
      width: auto;
      padding: 0;
      background: transparent;
      backdrop-filter: none;
      font-size: 0.825rem;
      gap: 0.4rem;
    }

    .btn-separator {
      display: none;
    }

    .hero-info {
      flex-direction: column;
      align-items: center;
      align-self: stretch;
      gap: 0.5rem;
    }
    
    .info-card {
      width: 85%;
      max-width: 320px;
      flex: none;
      padding: 0.45rem 0.875rem;
      border-radius: 12px;
      gap: 0.6rem;
      background: rgba(255, 255, 255, 0.08);
      border: 1px solid rgba(255, 255, 255, 0.15);
      backdrop-filter: none;
    }

    .info-text {
      gap: 0;
    }

    .info-label {
      font-size: 0.8rem;
      line-height: 1.2;
    }

    .info-detail {
      font-size: 0.72rem;
      line-height: 1.2;
    }

    .info-icon {
      min-width: 38px;
      height: 38px;
      padding: 0.5rem;
      border-radius: 12px;
    }

    .info-label {
      font-size: 0.825rem;
    }

    .info-detail {
      font-size: 0.75rem;
    }
  }
</style>